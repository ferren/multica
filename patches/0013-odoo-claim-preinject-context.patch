+// writePreInjectedIssueContext emits the `## Issue Context` section: the issue
+// body, metadata, and recently-active comments the backend pre-injected into
+// the claim response (方案B, TASK-1-17-1) so the agent starts turn 0 with full
+// context and skips the three read CLIs.
+//
+// Emitted for every issue-scoped kind (comment- and assignment-triggered) so
+// the agent always has ONE place describing how to acquire context:
+//
+//   - When the backend pre-injected content, the blocks are rendered here and
+//     the assignment workflow no longer needs numbered "run issue get /
+//     metadata list / comment list" steps — a one-line deep-dig pointer is
+//     enough. This is the whole point of 方案B: the agent reads context on
+//     turn 0 instead of burning three CLI/reasoning turns.
+//   - When nothing was pre-injected (old backend, or a truly empty issue), the
+//     blocks are omitted and a CLI fallback list takes their place, so behavior
+//     degrades to the status quo instead of leaving the agent contextless.
+//
+// The CLI command strings (issue get / metadata list / comment list) are kept
+// in the fallback so the agent can still reach the full record / long threads,
+// and so existing brief tests that pin those strings keep holding.
+func writePreInjectedIssueContext(b *strings.Builder, ctx TaskContextForEnv) {
+	b.WriteString("## Issue Context\n\n")
+	hasContent := false
+
+	if desc := strings.TrimSpace(ctx.IssueDescription); desc != "" {
+		hasContent = true
+		b.WriteString("**Issue description** (pre-injected):\n\n")
+		b.WriteString(desc)
+		b.WriteString("\n\n")
+	}
+
+	if meta := strings.TrimSpace(ctx.IssueMetadata); meta != "" && meta != "{}" && meta != "null" {
+		hasContent = true
+		b.WriteString("**Metadata** (pre-injected):\n\n```json\n")
+		b.WriteString(meta)
+		b.WriteString("\n```\n\n")
+	}
+
+	if len(ctx.RecentComments) > 0 {
+		hasContent = true
+		fmt.Fprintf(b, "**Recently active comments** (pre-injected, %d, capped — not the full history):\n\n", len(ctx.RecentComments))
+		for _, c := range ctx.RecentComments {
+			writeRecentCommentBlock(b, c)
+		}
+		b.WriteString("\n")
+	}
+
+	if hasContent {
+		// Context is already above; the workflow below no longer demands the
+		// three read CLIs as mandatory serial turns. Surface them only as
+		// deep-dig tools for the full record / long threads.
+		fmt.Fprintf(b, "This context is pre-injected by the backend. For the full record run `multica issue get %s --output json`; to page older or longer threads use `multica issue comment list %s --thread <comment-id> --tail 30 --output json` or `--recent 10` / `--since <RFC3339>` (resolved threads come back folded — `--full` to expand).\n\n", ctx.IssueID, ctx.IssueID)
+		return
+	}
+
+	// Old backend / empty issue: nothing was pre-injected. Fall back to the
+	// explicit fetch list so the agent still acquires context on turn 0.
+	fmt.Fprintf(b, "No context was pre-injected by this backend. Fetch it directly:\n")
+	fmt.Fprintf(b, "- `multica issue get %s --output json` for the issue body\n", ctx.IssueID)
+	fmt.Fprintf(b, "- `multica issue metadata list %s --output json` — best-effort, empty `{}` and CLI failures are normal. See the `## Issue Metadata` section above for what to look for.\n", ctx.IssueID)
+	fmt.Fprintf(b, "- `multica issue comment list %s --recent 10 --output json` for the recent discussion; page older threads with `--thread`/`--tail`/`--since` (resolved threads come back folded — `--full` to expand).\n\n", ctx.IssueID)
+}
+
+// writeRecentCommentBlock renders one pre-injected comment as a labelled
+// blockquote, mirroring the coalesced-comment rendering in daemon/prompt.go so
+// the persistent brief and the per-turn prompt stay visually consistent.
+func writeRecentCommentBlock(b *strings.Builder, c RecentCommentForEnv) {
+	authorLabel := "A user"
+	if c.AuthorType == "agent" {
+		name := c.AuthorName
+		if name == "" {
+			name = "another agent"
+		}
+		authorLabel = fmt.Sprintf("Another agent (%s)", name)
+	} else if c.AuthorName != "" {
+		authorLabel = c.AuthorName
+	}
+	fmt.Fprintf(b, "- comment `%s`", c.ID)
+	if c.CreatedAt != "" {
+		fmt.Fprintf(b, " (%s, %s)", authorLabel, c.CreatedAt)
+	} else {
+		fmt.Fprintf(b, " (%s)", authorLabel)
+	}
+	if c.ThreadID != "" {
+		fmt.Fprintf(b, " [thread `%s`]", c.ThreadID)
+	}
+	b.WriteString(":\n")
+	quoted := strings.ReplaceAll(strings.TrimSpace(c.Content), "\n", "\n  > ")
+	fmt.Fprintf(b, "  > %s\n", quoted)
+}
+
