+	// resolveOdooAuth calls /openapi/token with MULTICA_APP_ID + MULTICA_APP_SECRET
+	// to obtain access_token and api_key for Odoo OpenAPI auth.
+	func (d *Daemon) resolveOdooAuth() error {
+		appID := strings.TrimSpace(os.Getenv("MULTICA_APP_ID"))
+		appSecret := strings.TrimSpace(os.Getenv("MULTICA_APP_SECRET"))
+		if appID == "" || appSecret == "" {
+			return fmt.Errorf("MULTICA_APP_ID and MULTICA_APP_SECRET are required for Odoo backend mode")
+		}
+		ctx, cancel := context.WithTimeout(context.Background(), 15*time.Second)
+		defer cancel()
+		if err := d.client.FetchOdooToken(ctx, appID, appSecret, d.cfg.DBName); err != nil {
+			return fmt.Errorf("fetch odoo token: %w", err)
+		}
+		accessToken, _ := d.client.OdooCredentials()
+		d.logger.Info("authenticated (Odoo mode)", "expires_in", d.client.expiresIn, "db", d.cfg.DBName)
+		_ = accessToken
+		return nil
+	}
