+// odooTokenRefreshLoop periodically refreshes the Odoo OpenAPI access_token
+// before it expires. refreshAt = expires_in - 5 minutes (safe margin).
+func (d *Daemon) odooTokenRefreshLoop(ctx context.Context) {
+	appID := strings.TrimSpace(os.Getenv("MULTICA_APP_ID"))
+	appSecret := strings.TrimSpace(os.Getenv("MULTICA_APP_SECRET"))
+	for {
+		expiresIn := d.client.expiresIn
+		if expiresIn <= 0 {
+			expiresIn = 7200
+		}
+		refreshAt := time.Duration(expiresIn-300) * time.Second
+		if refreshAt < 60*time.Second {
+			refreshAt = 60 * time.Second
+		}
+		select {
+		case <-ctx.Done():
+			return
+		case <-time.After(refreshAt):
+			refreshCtx, cancel := context.WithTimeout(ctx, 15*time.Second)
+			if err := d.client.FetchOdooToken(refreshCtx, appID, appSecret, d.cfg.DBName); err != nil {
+				d.logger.Warn("odoo token refresh failed", "error", err)
+			} else {
+				d.logger.Info("odoo token refreshed", "expires_in", d.client.expiresIn, "db", d.cfg.DBName)
+			}
+			cancel()
+		}
+	}
+}
