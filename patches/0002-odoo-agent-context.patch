@@ -792,6 +792,34 @@ func buildMetaSkillContent(provider stri
 		b.WriteString("Bad: \"1. Read the issue 2. Found the bug in auth.go 3. Created branch 4. ...\"\n")
 		b.WriteString("When referencing an issue in a comment, use the issue mention format `[MUL-123](mention://issue/<issue-id>)` so it renders as a clickable link. (Issue mentions have no side effect; only member/agent mentions do — see the Mentions section above.)\n")
 	}
+	// Odoo backend: append Odoo-specific REST API context
+	if ctx.BackendMode == "odoo" {
+		b.WriteString("\n## Odoo Backend\n\n")
+		if ctx.OdooURL != "" {
+			fmt.Fprintf(&b, "Base URL: %s\n\n", ctx.OdooURL)
+		}
+		b.WriteString("### API Credentials\n")
+		if ctx.OdooAccessToken != "" {
+			fmt.Fprintf(&b, "X-GALAXY-ACCESS-TOKEN: Bearer %s\n", ctx.OdooAccessToken)
+		}
+		if ctx.OdooAPIKey != "" {
+			fmt.Fprintf(&b, "X-GALAXY-API-KEY: %s\n", ctx.OdooAPIKey)
+		}
+		b.WriteString("\n### REST APIs\n\n")
+		if ctx.OdooURL != "" && ctx.OdooAccessToken != "" {
+			fmt.Fprintf(&b, "- List:   `curl -s -H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s' -H 'X-MULTICA-AGENT-ID: %s' %s/multica/agent/issues`\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.AgentID, ctx.OdooURL)
+			fmt.Fprintf(&b, "- Create: `curl -s -X POST -H 'Content-Type: application/json' -H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s' -H 'X-MULTICA-AGENT-ID: %s' -d '{\"title\":\"...\"}' %s/multica/agent/issues`\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.AgentID, ctx.OdooURL)
+			fmt.Fprintf(&b, "- Get:    `curl -s -H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s' -H 'X-MULTICA-AGENT-ID: %s' %s/multica/agent/issues/<id>`\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.AgentID, ctx.OdooURL)
+			fmt.Fprintf(&b, "- Update: `curl -s -X PATCH -H 'Content-Type: application/json' -H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s' -H 'X-MULTICA-AGENT-ID: %s' -d '{\"status\":\"Done\"}' %s/multica/agent/issues/<id>`\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.AgentID, ctx.OdooURL)
+			fmt.Fprintf(&b, "- Comment:`curl -s -X POST -H 'Content-Type: application/json' -H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s' -H 'X-MULTICA-AGENT-ID: %s' -d '{\"body\":\"...\"}' %s/multica/agent/issues/<id>/comments`\n\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.AgentID, ctx.OdooURL)
+		}
+		b.WriteString("### Rules\n")
+		b.WriteString("1. Use the REST APIs above for issue/comment operations — no multica CLI for these\n")
+		b.WriteString("2. Work in current directory for file operations\n")
+		b.WriteString("3. Output a clear summary at the end\n")
+		b.WriteString("4. Odoo task status values: Backlog, Todo, In Progress, In Review, Done\n")
+		b.WriteString("5. Issue lifecycle — PATCH the issue status via the Update API above: BEFORE you begin work, set status to \"In Progress\"; WHEN finished, set \"In Review\" (work done, awaiting acceptance), or \"Done\" if fully complete, or \"Blocked\" if you cannot proceed. Skip this step only if your Agent Identity forbids issue status changes.\n")
+	}
 
 	return b.String()
 }
