+// TestLoadConfig_OdooModeKeepsGCOnAutoUpdateOff locks in the Odoo backend
+// defaults after GC was re-enabled: GC runs (inair_multica's gc-check endpoints
+// back it), while auto-update stays off (Odoo manages the daemon binary).
+func TestLoadConfig_OdooModeKeepsGCOnAutoUpdateOff(t *testing.T) {
+	stageFakeAgent(t)
+	t.Setenv("MULTICA_BACKEND_MODE", "odoo")
+	t.Setenv("MULTICA_GC_ENABLED", "") // no ambient opt-out
+	cfg, err := LoadConfig(Overrides{
+		ServerURL:      "http://localhost:8080",
+		WorkspacesRoot: t.TempDir(),
+	})
+	if err != nil {
+		t.Fatalf("LoadConfig: %v", err)
+	}
+	if !cfg.GCEnabled {
+		t.Fatalf("GCEnabled = false in Odoo mode, want true (gc-check endpoints back it)")
+	}
+	if cfg.AutoUpdateEnabled {
+		t.Fatalf("AutoUpdateEnabled = true in Odoo mode, want false")
+	}
+}
+
 // TestLoadConfig_AutoUpdate_NoFlagWinsOverCloudDefault keeps the legacy CLI
 // flag working: --no-auto-update (translated into overrides.DisableAutoUpdate)
 // forces auto-update off even when the cloud default and env var would enable.
