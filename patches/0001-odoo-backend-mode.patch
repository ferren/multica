+// TestClient_FetchOdooToken_OmittedAPIKeyKeepsCachedOne guards the case Odoo
+// documents in inair_open_api_app.py get_access_key: api_key is only present
+// on a response that actually issued a *new* access_token (is_new=True); a
+// response that instead reused/extended an existing one omits api_key
+// entirely, it does not send it back empty on purpose. FetchOdooToken must
+// treat that omission as "unchanged", not as "clear the apiKey" — otherwise a
+// legitimate reuse response would wipe out a perfectly valid cached apiKey
+// and break every subsequent request until the next lucky fetch that happens
+// to include one.
+func TestClient_FetchOdooToken_OmittedAPIKeyKeepsCachedOne(t *testing.T) {
+	var call atomic.Int32
+	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		w.Header().Set("Content-Type", "application/json")
+		if call.Add(1) == 1 {
+			json.NewEncoder(w).Encode(map[string]any{
+				"access_token": "tok-1",
+				"api_key":      "key-1",
+				"expires_in":   7200,
+			})
+			return
+		}
+		// Second call: server extends the existing access_token and omits
+		// api_key, exactly as /openapi/token does for a reused session.
+		json.NewEncoder(w).Encode(map[string]any{
+			"access_token": "tok-2",
+			"expires_in":   7200,
+		})
+	}))
+	defer srv.Close()
+
+	c := NewClient(srv.URL)
+	if err := c.FetchOdooToken(context.Background(), "app", "secret", ""); err != nil {
+		t.Fatalf("first FetchOdooToken: %v", err)
+	}
+	if err := c.FetchOdooToken(context.Background(), "app", "secret", ""); err != nil {
+		t.Fatalf("second FetchOdooToken: %v", err)
+	}
+
+	accessToken, apiKey := c.OdooCredentials()
+	if accessToken != "tok-2" {
+		t.Errorf("accessToken = %q, want tok-2 (should pick up the renewed token)", accessToken)
+	}
+	if apiKey != "key-1" {
+		t.Errorf("apiKey = %q, want key-1 (must keep the cached key, not be wiped by the omission)", apiKey)
+	}
+}
+
+// TestClient_FetchOdooToken_NoAPIKeyEverIsAnError is the flip side: if the
+// very first fetch doesn't come with an api_key, there is nothing cached to
+// fall back on, so it must fail loudly instead of silently leaving the
+// client with no way to authenticate.
+func TestClient_FetchOdooToken_NoAPIKeyEverIsAnError(t *testing.T) {
+	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		w.Header().Set("Content-Type", "application/json")
+		json.NewEncoder(w).Encode(map[string]any{
+			"access_token": "tok-1",
+			"expires_in":   7200,
+		})
+	}))
+	defer srv.Close()
+
+	c := NewClient(srv.URL)
+	if err := c.FetchOdooToken(context.Background(), "app", "secret", ""); err == nil {
+		t.Fatal("expected an error when no api_key has ever been provided, got nil")
+	}
+}
