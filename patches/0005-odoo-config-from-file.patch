+// TestResolveOdooAuth_TokenErrorCallbackRefreshesAndMatches exercises
+// resolveOdooAuth end to end against a fake /openapi/token endpoint: it must
+// fetch an initial token, then wire up an onTokenError callback that
+// (through the now-locked-and-deduped Client.FetchOdooToken) fetches a fresh,
+// *matched* accessToken/apiKey pair when invoked — using the daemon's own
+// configured app id/secret/db, not stale or mismatched values.
+func TestResolveOdooAuth_TokenErrorCallbackRefreshesAndMatches(t *testing.T) {
+	var calls atomic.Int32
+	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		if got := r.URL.Query().Get("appid"); got != "app-1" {
+			t.Errorf("appid = %q, want app-1", got)
+		}
+		if got := r.URL.Query().Get("secret"); got != "secret-1" {
+			t.Errorf("secret = %q, want secret-1", got)
+		}
+		if got := r.URL.Query().Get("db"); got != "db-1" {
+			t.Errorf("db = %q, want db-1", got)
+		}
+		n := calls.Add(1)
+		w.Header().Set("Content-Type", "application/json")
+		json.NewEncoder(w).Encode(map[string]any{
+			"access_token": fmt.Sprintf("tok-%d", n),
+			"api_key":      fmt.Sprintf("key-%d", n),
+			"expires_in":   7200,
+		})
+	}))
+	defer srv.Close()
+
+	d := New(Config{
+		BackendMode:    "odoo",
+		ServerBaseURL:  srv.URL,
+		AppID:          "app-1",
+		AppSecret:      "secret-1",
+		DBName:         "db-1",
+		WorkspacesRoot: t.TempDir(),
+	}, slog.Default())
+
+	if err := d.resolveOdooAuth(); err != nil {
+		t.Fatalf("resolveOdooAuth: %v", err)
+	}
+	firstAccess, firstKey := d.client.OdooCredentials()
+	if firstAccess != "tok-1" || firstKey != "key-1" {
+		t.Fatalf("unexpected initial credentials: accessToken=%q apiKey=%q", firstAccess, firstKey)
+	}
+
+	// Simulate a 401: invoke the callback resolveOdooAuth registered on the
+	// client, exactly as postJSONVia/getJSON would on token expiry.
+	d.client.onTokenError()
+
+	secondAccess, secondKey := d.client.OdooCredentials()
+	if secondAccess != "tok-2" || secondKey != "key-2" {
+		t.Fatalf("unexpected refreshed credentials: accessToken=%q apiKey=%q", secondAccess, secondKey)
+	}
+	if got := calls.Load(); got != 2 {
+		t.Fatalf("expected 2 token fetches (initial + refresh), got %d", got)
+	}
+}
