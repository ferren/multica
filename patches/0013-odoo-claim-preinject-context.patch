+// readFilename is a small helper for brief-render tests that write into a
+// temp dir under both CLAUDE.md and AGENTS.md depending on provider/kind.
+func readFilename(t *testing.T, dir, name string) string {
+	t.Helper()
+	data, err := os.ReadFile(filepath.Join(dir, name))
+	if err != nil {
+		t.Fatalf("read %s: %v", name, err)
+	}
+	return string(data)
+}
