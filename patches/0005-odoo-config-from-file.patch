+// TestOdooTokenRefreshLoop_FailureRetriesSoonNotAfterFullCycle pins the
+// relationship between the two odooTokenRefreshLoop timing constants: a
+// failed refresh must retry much sooner than the normal expires_in-based
+// cadence. Before this fix, a failed refresh recomputed the wait from the
+// stale (unchanged) expires_in and ended up sleeping almost a full token
+// lifetime again — during which the token could already be expired — before
+// trying once more. If a future change collapses these back to the same
+// value, this test catches it.
+func TestOdooTokenRefreshLoop_FailureRetriesSoonNotAfterFullCycle(t *testing.T) {
+	if odooTokenRefreshFailureRetryInterval != 30*time.Second {
+		t.Errorf("odooTokenRefreshFailureRetryInterval = %s, want 30s", odooTokenRefreshFailureRetryInterval)
+	}
+	if odooTokenRefreshLoopMinInterval != 60*time.Second {
+		t.Errorf("odooTokenRefreshLoopMinInterval = %s, want 60s", odooTokenRefreshLoopMinInterval)
+	}
+	// The normal steady-state wait for a realistic expires_in (e.g. 7200s,
+	// the loop's own fallback default) must dwarf the failure retry — that
+	// gap is exactly what used to leave the daemon stuck on an
+	// expired/expiring token after one failed refresh.
+	steadyState := time.Duration(7200-300) * time.Second
+	if odooTokenRefreshFailureRetryInterval >= steadyState/10 {
+		t.Errorf("failure retry interval %s is not meaningfully shorter than the steady-state wait %s", odooTokenRefreshFailureRetryInterval, steadyState)
+	}
+}
