+		if strings.Contains(s, "No context was pre-injected") {
+			t.Errorf("rich brief should not show the empty-issue fallback\n---\n%s", s)
+		}
+	})
+
+	t.Run("empty_issue_falls_back_to_cli_list", func(t *testing.T) {
+		t.Parallel()
+		dir := t.TempDir()
+		if _, err := InjectRuntimeConfig(dir, "claude", TaskContextForEnv{IssueID: "issue-bare"}); err != nil {
+			t.Fatalf("InjectRuntimeConfig failed: %v", err)
+		}
+		s := readFilename(t, dir, "CLAUDE.md")
+		for _, want := range []string{
+			"## Issue Context",
+			"No context was pre-injected by this backend",
+			"multica issue get issue-bare --output json",
+			"multica issue metadata list issue-bare --output json",
+			"multica issue comment list issue-bare --recent 10 --output json",
