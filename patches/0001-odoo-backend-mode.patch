+// FetchOdooToken calls GET /openapi/token with appid+secret to obtain
+// access_token and api_key, storing both for subsequent requests. Concurrent
+// callers (a 401 on one request racing another, or the refresh loop's timer
+// firing at the same instant a request 401s) are coalesced via tokenRefresh
+// into a single HTTP round trip that they all share the result of — this is
+// what keeps accessToken/apiKey from ending up as a mismatched pair written
+// by two overlapping fetches.
+func (c *Client) FetchOdooToken(ctx context.Context, appID, appSecret, dbName string) error {
+	_, err, _ := c.tokenRefresh.Do(odooTokenRefreshKey, func() (any, error) {
+		return nil, c.fetchOdooTokenOnce(ctx, appID, appSecret, dbName)
+	})
+	return err
+}
+
+func (c *Client) fetchOdooTokenOnce(ctx context.Context, appID, appSecret, dbName string) error {
+	u, err := url.Parse(c.baseURL + "/openapi/token")
+	if err != nil {
+		return fmt.Errorf("parse token url: %w", err)
+	}
+	q := u.Query()
+	q.Set("grant_type", "client_credential")
+	q.Set("appid", appID)
+	q.Set("secret", appSecret)
+	if dbName != "" {
+		q.Set("db", dbName)
+	}
+	u.RawQuery = q.Encode()
+
+	req, err := http.NewRequestWithContext(ctx, http.MethodGet, u.String(), nil)
+	if err != nil {
+		return err
+	}
+
+	resp, err := c.client.Do(req)
+	if err != nil {
+		return fmt.Errorf("fetch odoo token: %w", err)
+	}
+	defer resp.Body.Close()
+
+	data, _ := io.ReadAll(io.LimitReader(resp.Body, 4096))
+	if resp.StatusCode != 200 {
+		return fmt.Errorf("fetch odoo token: %d: %s", resp.StatusCode, strings.TrimSpace(string(data)))
+	}
+
+	var tokenResp struct {
+		AccessToken string `json:"access_token"`
+		ExpiresIn   int    `json:"expires_in"`
+		APIKey      string `json:"api_key"`
+		Code        int    `json:"code"`
+		Message     string `json:"message"`
+	}
+	if err := json.Unmarshal(data, &tokenResp); err != nil {
+		return fmt.Errorf("fetch odoo token: decode: %w", err)
+	}
+	if tokenResp.Code != 0 {
+		return fmt.Errorf("fetch odoo token: code=%d message=%s", tokenResp.Code, tokenResp.Message)
+	}
+	if tokenResp.AccessToken == "" {
+		return fmt.Errorf("fetch odoo token: empty access_token")
+	}
+
+	// The server only includes api_key on the response that actually issues a
+	// new access_token (Odoo's /openapi/token returns it conditionally on
+	// "is_new" — see inair_open_api_app.py get_access_key). A call that instead
+	// reuses/extends an existing access_token (same Odoo session, still within
+	// its safety margin) omits api_key entirely. An empty APIKey here therefore
+	// does not mean "no key" — it means "unchanged" — so it must never
+	// overwrite whatever apiKey we already have cached. Only error out if we
+	// end up with no apiKey at all, i.e. this is the very first fetch and the
+	// server didn't hand us one to start with.
+	c.tokenMu.Lock()
+	c.accessToken = tokenResp.AccessToken
+	if tokenResp.APIKey != "" {
+		c.apiKey = tokenResp.APIKey
+	}
+	c.expiresIn = tokenResp.ExpiresIn
+	haveAPIKey := c.apiKey != ""
+	c.tokenMu.Unlock()
+
+	if !haveAPIKey {
+		return fmt.Errorf("fetch odoo token: server never returned an api_key for this app")
+	}
+	return nil
+}
+
+// SetOnTokenError registers a callback invoked when a 401 is received.
+func (c *Client) SetOnTokenError(fn func()) {
+	c.onTokenError = fn
+}
+
+// OdooCredentials returns the current Odoo OpenAPI token pair.
+func (c *Client) OdooCredentials() (accessToken, apiKey string) {
+	c.tokenMu.RLock()
+	defer c.tokenMu.RUnlock()
+	return c.accessToken, c.apiKey
+}
+
+// OdooExpiresIn returns the lifetime (in seconds) reported by the last
+// successful FetchOdooToken call, or 0 if none has succeeded yet.
+func (c *Client) OdooExpiresIn() int {
+	c.tokenMu.RLock()
+	defer c.tokenMu.RUnlock()
+	return c.expiresIn
+}
+
+// MintAgentToken exchanges the daemon's shared Odoo credentials for a fresh
+// access_token/api_key pair scoped to a single agent (Odoo backend mode
+// only; see inair_multica's /multica/daemon/agents/<id>/token). The daemon
+// injects the result into that agent's task env instead of the shared pair,
+// so Odoo can identify which agent is calling from the credential itself —
+// no self-reported header needed.
+func (c *Client) MintAgentToken(ctx context.Context, agentID string) (accessToken, apiKey string, expiresIn int, err error) {
+	var resp struct {
+		AccessToken string `json:"access_token"`
+		APIKey      string `json:"api_key"`
+		ExpiresIn   int    `json:"expires_in"`
+	}
+	path := fmt.Sprintf("%s/daemon/agents/%s/token", c.pathPrefix, agentID)
+	if err := c.postJSON(ctx, path, nil, &resp); err != nil {
+		return "", "", 0, err
+	}
+	return resp.AccessToken, resp.APIKey, resp.ExpiresIn, nil
+}
