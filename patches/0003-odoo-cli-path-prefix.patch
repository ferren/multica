 // NewAPIClient creates a new API client for ctrl commands.
 func NewAPIClient(baseURL, workspaceID, token string) *APIClient {
-	return &APIClient{
+	c := &APIClient{
 		BaseURL:     strings.TrimRight(baseURL, "/"),
 		WorkspaceID: workspaceID,
 		Token:       token,
 		HTTPClient:  &http.Client{Timeout: httpTimeout()},
 	}
+	// Odoo backend mode serves the agent API under /multica/agent instead of
+	// the native /api; rewrite the hardcoded /api prefix so CLI subcommands
+	// (squad, issue, project, agent, skill, autopilot, ...) reach the Odoo
+	// controllers. Native mode leaves PathPrefix empty (no rewrite).
+	if os.Getenv("MULTICA_BACKEND_MODE") == "odoo" {
+		c.PathPrefix = "/multica/agent"
+	}
+	return c
+}
+
+// url builds the absolute request URL. In Odoo backend mode it rewrites the
+// hardcoded native "/api" prefix to the configured PathPrefix
+// ("/multica/agent"); other paths (e.g. "/health") are left untouched.
+func (c *APIClient) url(path string) string {
+	if c.PathPrefix != "" && strings.HasPrefix(path, "/api") {
+		path = c.PathPrefix + strings.TrimPrefix(path, "/api")
+	}
+	return c.BaseURL + path
 }
 
