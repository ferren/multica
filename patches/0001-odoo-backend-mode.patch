+	// connectDaemon registers this daemon and its detected runtimes on the Odoo
+	// server at startup. Runtimes are created without agent binding and become
+	// available for agent assignment in the Odoo UI.
+	func (d *Daemon) connectDaemon(ctx context.Context) error {
+		var runtimes []map[string]string
+		for name, entry := range d.cfg.Agents {
+			version, err := detectAgentVersion(ctx, entry.Path)
+			if err != nil {
+				d.logger.Warn("skip runtime for connect", "name", name, "error", err)
+				continue
+			}
+			if err := checkAgentMinVersion(name, version); err != nil {
+				d.logger.Warn("skip runtime for connect: version too old", "name", name, "version", version, "error", err)
+				continue
+			}
+			d.setAgentVersion(name, version)
+			displayName := strings.ToUpper(name[:1]) + name[1:]
+			if d.cfg.DeviceName != "" {
+				displayName = fmt.Sprintf("%s (%s)", displayName, d.cfg.DeviceName)
+			}
+			runtimes = append(runtimes, map[string]string{
+				"name":    displayName,
+				"type":    name,
+				"version": version,
+			})
+		}
+		if len(runtimes) == 0 {
+			return fmt.Errorf("no agent runtimes detected: install claude or another supported agent CLI")
+		}
+
+		req := map[string]any{
+			"daemon_id":    d.cfg.DaemonID,
+			"device_name":  d.cfg.DeviceName,
+			"cli_version":  d.cfg.CLIVersion,
+			"launched_by":  d.cfg.LaunchedBy,
+			"runtimes":     runtimes,
+		}
+
+		connectCtx, cancel := context.WithTimeout(ctx, 15*time.Second)
+		defer cancel()
+		resp, err := d.client.Connect(connectCtx, req)
+		if err != nil {
+			return err
+		}
+
+		d.mu.Lock()
+		for _, rt := range resp.Runtimes {
+			d.oursRuntimeIDs[rt.ID] = true
+			d.runtimeIndex[rt.ID] = rt
+			d.logger.Info("runtime available", "runtime_id", rt.ID, "provider", rt.Provider, "name", rt.Name)
+		}
+		d.mu.Unlock()
+
+		d.logger.Info("daemon connected (Odoo mode)", "daemon_id", d.cfg.DaemonID, "runtimes", len(resp.Runtimes))
+		return nil
+	}
+	// odooTokenRefreshLoop periodically refreshes the Odoo OpenAPI access_token
+	// before it expires. refreshAt = expires_in - 5 minutes (safe margin).
+	func (d *Daemon) odooTokenRefreshLoop(ctx context.Context) {
+		appID := strings.TrimSpace(os.Getenv("MULTICA_APP_ID"))
+		appSecret := strings.TrimSpace(os.Getenv("MULTICA_APP_SECRET"))
+		for {
+			expiresIn := d.client.expiresIn
+			if expiresIn <= 0 {
+				expiresIn = 7200
+			}
+			refreshAt := time.Duration(expiresIn-300) * time.Second
+			if refreshAt < 60*time.Second {
+				refreshAt = 60 * time.Second
+			}
+			select {
+			case <-ctx.Done():
+				return
+			case <-time.After(refreshAt):
+				refreshCtx, cancel := context.WithTimeout(ctx, 15*time.Second)
+				if err := d.client.FetchOdooToken(refreshCtx, appID, appSecret, d.cfg.DBName); err != nil {
+					d.logger.Warn("odoo token refresh failed", "error", err)
+				} else {
+					d.logger.Info("odoo token refreshed", "expires_in", d.client.expiresIn, "db", d.cfg.DBName)
+				}
+				cancel()
+			}
+		}
+	}
