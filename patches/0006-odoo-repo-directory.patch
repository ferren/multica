+// safeRelDir normalizes a backend-supplied checkout subdirectory into a safe
+// relative path (may be nested, e.g. "frontend/app"). It rejects absolute paths
+// and anything that would escape the worktree parent via ".." segments,
+// returning "" for empty/unsafe input so the caller falls back to the
+// URL-derived repo name.
+func safeRelDir(dir string) string {
+	dir = strings.TrimSpace(dir)
+	if dir == "" {
+		return ""
+	}
+	dir = filepath.ToSlash(dir)
+	if strings.HasPrefix(dir, "/") {
+		return ""
+	}
+	cleaned := filepath.ToSlash(filepath.Clean(dir))
+	if cleaned == "." || cleaned == ".." || strings.HasPrefix(cleaned, "../") {
+		return ""
+	}
+	return filepath.FromSlash(cleaned)
+}
