Index: multica/server/internal/daemon/execenv/runtime_config_sections.go
===================================================================
--- multica.orig/server/internal/daemon/execenv/runtime_config_sections.go
+++ multica/server/internal/daemon/execenv/runtime_config_sections.go
@@ -2,6 +2,7 @@ package execenv
 
 import (
 	"fmt"
+	"path/filepath"
 	"strings"
 
 	"github.com/multica-ai/multica/server/internal/runtimeapps"
@@ -600,5 +601,50 @@ func buildMetaSkillContentSlim(provider
 	writeAlwaysUseCLI(&b)
 	writeOutput(&b, kind, ctx)
 
+	// Odoo backend: append Odoo-specific REST API context
+	if ctx.BackendMode == "odoo" {
+		b.WriteString("\n## Odoo Backend\n\n")
+		if ctx.OdooURL != "" {
+			fmt.Fprintf(&b, "Base URL: %s\n\n", ctx.OdooURL)
+		}
+		b.WriteString("### Required Headers\n")
+		b.WriteString("**EVERY** request below MUST send both of these headers, on every single call. They are scoped to you specifically — Odoo identifies which agent is acting from the credential itself, so there is no separate agent-id header to remember:\n\n")
+		if ctx.OdooAccessToken != "" {
+			fmt.Fprintf(&b, "- `X-GALAXY-ACCESS-TOKEN: Bearer %s`\n", ctx.OdooAccessToken)
+		}
+		if ctx.OdooAPIKey != "" {
+			fmt.Fprintf(&b, "- `X-GALAXY-API-KEY: %s`\n", ctx.OdooAPIKey)
+		}
+		b.WriteString("\nTip: keep these as a shell variable so you cannot forget one, e.g.\n")
+		if ctx.OdooAccessToken != "" {
+			fmt.Fprintf(&b, "```sh\nH=(-H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s')\ncurl -s \"${H[@]}\" %s/multica/agent/issues/<id>\n```\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.OdooURL)
+		}
+		// Resumed sessions carry the previous run's (now-rotated) header values
+		// in their own conversation history; the file on disk is rewritten with
+		// fresh credentials every run, so a 401 means "re-read the file", not
+		// "the backend is broken".
+		briefFile := filepath.Base(runtimeConfigPath(".", provider))
+		if briefFile == "" || briefFile == "." {
+			briefFile = "CLAUDE.md / AGENTS.md"
+		}
+		fmt.Fprintf(&b, "\n⚠️ These credentials are re-issued fresh for every run and expire between runs. If any request returns **401**, the header values you are using are stale — this is expected in a resumed session, where your earlier messages contain last run's now-expired credentials. Do NOT keep retrying the same values and do NOT abandon the task: re-read the Required Headers section of `%s` in your working directory (the file has already been rewritten with fresh credentials), rebuild your header variable from it, and retry.\n", briefFile)
+		b.WriteString("\n### REST APIs\n\n")
+		b.WriteString("All examples already include the two required headers above — copy them verbatim:\n\n")
+		if ctx.OdooURL != "" && ctx.OdooAccessToken != "" {
+			fmt.Fprintf(&b, "- List:   `curl -s -H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s' %s/multica/agent/issues`\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.OdooURL)
+			fmt.Fprintf(&b, "- Create: `curl -s -X POST -H 'Content-Type: application/json' -H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s' -d '{\"title\":\"...\"}' %s/multica/agent/issues`\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.OdooURL)
+			fmt.Fprintf(&b, "- Get:    `curl -s -H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s' %s/multica/agent/issues/<id>`\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.OdooURL)
+			fmt.Fprintf(&b, "- Update: `curl -s -X PATCH -H 'Content-Type: application/json' -H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s' -d '{\"status\":\"Done\"}' %s/multica/agent/issues/<id>`\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.OdooURL)
+			fmt.Fprintf(&b, "- Comment:`curl -s -X POST -H 'Content-Type: application/json' -H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s' -d '{\"body\":\"...\"}' %s/multica/agent/issues/<id>/comments`\n\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.OdooURL)
+		}
+		b.WriteString("### Rules\n")
+		b.WriteString("1. Use the REST APIs above for issue/comment operations — no multica CLI for these\n")
+		fmt.Fprintf(&b, "1a. On any **401** response: re-read the Required Headers from `%s` and retry with the fresh values — never reuse header values remembered from earlier in a resumed conversation.\n", briefFile)
+		b.WriteString("2. Work in current directory for file operations\n")
+		b.WriteString("3. Output a clear summary at the end\n")
+		b.WriteString("4. Odoo task status values: Backlog, Todo, In Progress, In Review, Done\n")
+		b.WriteString("5. Issue lifecycle — PATCH the issue status via the Update API above: BEFORE you begin work, set status to \"In Progress\"; WHEN finished, set \"In Review\" (work done, awaiting acceptance), or \"Done\" if fully complete, or \"Blocked\" if you cannot proceed. Skip this step only if your Agent Identity forbids issue status changes.\n")
+	}
+
 	return b.String()
 }
