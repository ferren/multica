+func buildOdooMetaSkillContent(provider string, ctx TaskContextForEnv) string {
+	var b strings.Builder
+	b.WriteString("# Odoo Agent Runtime\n\n")
+	b.WriteString("You are an AI coding agent in **Odoo via inair_multica**. Use the REST APIs below.\n\n")
+	if ctx.AgentName != "" {
+		fmt.Fprintf(&b, "**You are: %s**\n\n", ctx.AgentName)
+	}
+	if ctx.AgentInstructions != "" {
+		b.WriteString(ctx.AgentInstructions)
+		b.WriteString("\n\n")
+	}
+	b.WriteString("## API Credentials\n")
+	if ctx.OdooAccessToken != "" {
+		fmt.Fprintf(&b, "X-GALAXY-ACCESS-TOKEN: Bearer %s\n", ctx.OdooAccessToken)
+	}
+	if ctx.OdooAPIKey != "" {
+		fmt.Fprintf(&b, "X-GALAXY-API-KEY: %s\n", ctx.OdooAPIKey)
+	}
+	if ctx.OdooURL != "" {
+		fmt.Fprintf(&b, "Base URL: %s\n\n", ctx.OdooURL)
+	}
+	b.WriteString("## APIs\n\n")
+	if ctx.OdooURL != "" && ctx.OdooAccessToken != "" {
+		fmt.Fprintf(&b, "List:   curl -s -H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s' %s/multica/agent/issues\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.OdooURL)
+		fmt.Fprintf(&b, "Create: curl -s -X POST -H 'Content-Type: application/json' -H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s' -d '{\"title\":\"...\"}' %s/multica/agent/issues\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.OdooURL)
+		fmt.Fprintf(&b, "Get:    curl -s -H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s' %s/multica/agent/issues/<id>\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.OdooURL)
+		fmt.Fprintf(&b, "Update: curl -s -X PATCH -H 'Content-Type: application/json' -H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s' -d '{\"status\":\"Done\"}' %s/multica/agent/issues/<id>\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.OdooURL)
+		fmt.Fprintf(&b, "Comment:curl -s -X POST -H 'Content-Type: application/json' -H 'X-GALAXY-ACCESS-TOKEN: Bearer %s' -H 'X-GALAXY-API-KEY: %s' -d '{\"body\":\"...\"}' %s/multica/agent/issues/<id>/comments\n\n", ctx.OdooAccessToken, ctx.OdooAPIKey, ctx.OdooURL)
+	}
+	b.WriteString("## Rules\n")
+	b.WriteString("1. Use the REST APIs above — no multica CLI\n")
+	b.WriteString("2. Work in current directory for file ops\n")
+	b.WriteString("3. Output a clear summary — posted to Odoo\n")
+	b.WriteString("4. Status values: Backlog, Todo, In Progress, In Review, Done\n")
+	return b.String()
+}
