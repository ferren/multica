+// numericIDRegexp matches a pure positive integer. The Odoo backend keys records
+// by integer ID rather than UUID, so in that mode a bare number is a direct ID.
+var numericIDRegexp = regexp.MustCompile(`^[0-9]+$`)
+
+// looksLikeDirectID reports whether s should be forwarded as a record ID as-is
+// rather than resolved as a name/prefix. A canonical UUID always qualifies; in
+// Odoo backend mode (MULTICA_BACKEND_MODE=odoo) a pure integer also qualifies.
+func looksLikeDirectID(s string) bool {
+	if uuidRegexp.MatchString(s) {
