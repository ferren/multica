+// TestPreInjectedIssueContext locks in 方案B (TASK-1-17-1): the backend
+// pre-injects the issue body / metadata / recent comments into the brief's
+// `## Issue Context` section so the agent starts turn 0 with full context. The
+// section must render every injected block when present, fall back to an
+// explicit CLI fetch list when nothing was injected (old backend / bare issue),
+// and appear only on the issue-scoped kinds (comment / assignment) — never on
+// chat / quick-create / autopilot.
+func TestPreInjectedIssueContext(t *testing.T) {
+	t.Parallel()
+
+	richAssignment := TaskContextForEnv{
+		IssueID:          "issue-rich",
+		IssueDescription: "Replace the login redirect. See spec below.",
