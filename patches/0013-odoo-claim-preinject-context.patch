+			ThreadID:   "t1",
+			AuthorType: "member",
+			AuthorName: "Alice",
+			Content:    "Please also handle the logout path.",
+			CreatedAt:  "2026-07-19T10:00:00Z",
+		}, {
+			ID:         "c2",
+			ThreadID:   "t1",
+			AuthorType: "agent",
+			AuthorName: "bob-bot",
+			Content:    "On it. Pushed a draft.",
+			CreatedAt:  "2026-07-19T11:00:00Z",
+		}},
+	}
+
+	t.Run("assignment_renders_all_blocks", func(t *testing.T) {
+		t.Parallel()
+		dir := t.TempDir()
+		if _, err := InjectRuntimeConfig(dir, "claude", richAssignment); err != nil {
+			t.Fatalf("InjectRuntimeConfig failed: %v", err)
+		}
+		s := readFilename(t, dir, "CLAUDE.md")
+		for _, want := range []string{
+			"## Issue Context",
+			"**Issue description** (pre-injected)",
+			"Replace the login redirect.",
+			"**Metadata** (pre-injected)",
+			`"pr_url": "https://example.com/pr/1"`,
+			"**Recently active comments**",
+			"comment `c1`",
+			"Alice",
+			"Another agent (bob-bot)",
+			"[thread `t1`]",
+			"This context is pre-injected by the backend",
+		} {
+			if !strings.Contains(s, want) {
+				t.Errorf("rich assignment brief missing %q\n---\n%s", want, s)
+			}
+		}
