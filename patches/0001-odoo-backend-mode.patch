+	var wg sync.WaitGroup
+	wg.Add(n)
+	for i := 0; i < n; i++ {
+		go func() {
+			defer wg.Done()
+			if err := c.FetchOdooToken(context.Background(), "app", "secret", ""); err != nil {
+				t.Errorf("FetchOdooToken: %v", err)
+			}
+		}()
+	}
+	wg.Wait()
+
+	if got := calls.Load(); got != 1 {
+		t.Fatalf("expected exactly 1 HTTP call to /openapi/token (deduped), got %d", got)
+	}
+	accessToken, apiKey := c.OdooCredentials()
+	suffix := strings.TrimPrefix(accessToken, "tok-")
+	if suffix == accessToken || apiKey != "key-"+suffix {
+		t.Fatalf("mismatched credential pair: accessToken=%q apiKey=%q", accessToken, apiKey)
+	}
+}
+
+// TestClient_PostJSON_RetriesOnceAfterOdooTokenRefresh verifies that an
+// ordinary token-expiry 401 is invisible to the caller: postJSONVia should
+// refresh (via onTokenError) and retry the same request once with the new
+// credentials, rather than surfacing the first 401 as an error.
+func TestClient_PostJSON_RetriesOnceAfterOdooTokenRefresh(t *testing.T) {
+	var tokenCalls atomic.Int32
+	var apiCalls atomic.Int32
+	var mu sync.Mutex
+	validKey := ""
+
+	mux := http.NewServeMux()
+	mux.HandleFunc("/openapi/token", func(w http.ResponseWriter, r *http.Request) {
+		n := tokenCalls.Add(1)
+		newKey := fmt.Sprintf("key-%d", n)
+		mu.Lock()
+		validKey = newKey
+		mu.Unlock()
+		w.Header().Set("Content-Type", "application/json")
+		json.NewEncoder(w).Encode(map[string]any{
+			"access_token": fmt.Sprintf("tok-%d", n),
+			"api_key":      newKey,
+			"expires_in":   7200,
+		})
+	})
+	mux.HandleFunc("/api/daemon/test", func(w http.ResponseWriter, r *http.Request) {
+		apiCalls.Add(1)
+		mu.Lock()
+		key := validKey
+		mu.Unlock()
+		if r.Header.Get("X-GALAXY-API-KEY") != key {
+			w.WriteHeader(http.StatusUnauthorized)
+			return
+		}
+		w.WriteHeader(http.StatusOK)
+	})
+	srv := httptest.NewServer(mux)
+	defer srv.Close()
+
+	c := NewClient(srv.URL)
+	// Seed a stale credential pair, mimicking a token that expired since the
+	// daemon's last successful fetch.
+	c.accessToken = "stale-token"
+	c.apiKey = "stale-key"
+	c.SetOnTokenError(func() {
+		ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
+		defer cancel()
+		_ = c.FetchOdooToken(ctx, "app", "secret", "")
+	})
+
+	if err := c.postJSON(context.Background(), "/api/daemon/test", nil, nil); err != nil {
+		t.Fatalf("postJSON: %v", err)
+	}
+	if got := apiCalls.Load(); got != 2 {
+		t.Fatalf("expected 2 calls to /api/daemon/test (401 then retry), got %d", got)
+	}
+	if got := tokenCalls.Load(); got != 1 {
+		t.Fatalf("expected exactly 1 token refresh, got %d", got)
+	}
+}
