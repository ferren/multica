+// TestClient_FetchOdooToken_ConcurrentCallsAreDeduped guards against the bug
+// where every goroutine that sees a 401 at the moment the Odoo access_token
+// truly expires (heartbeat, workspace sync, task poll, the refresh loop's own
+// timer — all independent goroutines) called FetchOdooToken on its own. With
+// no locking, two overlapping fetches could interleave their writes to
+// accessToken/apiKey and leave a mismatched pair that the server rejects
+// forever. tokenRefresh (singleflight) should collapse concurrent callers
+// into exactly one HTTP round trip, and tokenMu should make the result
+// visible as one atomic, matched pair. Run with -race to catch the data race
+// directly, not just the symptom.
+func TestClient_FetchOdooToken_ConcurrentCallsAreDeduped(t *testing.T) {
+	var calls atomic.Int32
+	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		n := calls.Add(1)
+		// Widen the race window so concurrent callers are likely to overlap
+		// even on a fast machine.
+		time.Sleep(20 * time.Millisecond)
+		w.Header().Set("Content-Type", "application/json")
