+// taskRepoDirectory returns the configured checkout subdirectory (relative to
+// the task workdir) for a repo, or "" when none is set. Mirrors
+// taskRepoDefaultRef so the /repo/checkout handler can honor the backend's
+// per-repo "检出目录" setting server-side rather than trusting the agent.
+func (d *Daemon) taskRepoDirectory(workspaceID, taskID, repoURL string) string {
+	taskID = strings.TrimSpace(taskID)
+	repoURL = strings.TrimSpace(repoURL)
+	if taskID == "" || repoURL == "" {
+		return ""
+	}
+	d.mu.Lock()
+	defer d.mu.Unlock()
+	ws, ok := d.workspaces[workspaceID]
+	if !ok || ws.taskRepoDirs == nil {
+		return ""
+	}
+	return strings.TrimSpace(ws.taskRepoDirs[taskID][repoURL])
+}
