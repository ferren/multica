+// setAuthHeaders attaches authentication headers. When apiKey is set (Odoo
+// mode), sends X-GALAXY-ACCESS-TOKEN + X-GALAXY-API-KEY. Otherwise falls back
+// to Bearer token.
+func (c *Client) setAuthHeaders(req *http.Request) {
+	c.setIdentityHeaders(req)
+	c.tokenMu.RLock()
+	apiKey, accessToken := c.apiKey, c.accessToken
+	c.tokenMu.RUnlock()
+	if apiKey != "" {
+		req.Header.Set("X-GALAXY-ACCESS-TOKEN", "Bearer "+accessToken)
+		req.Header.Set("X-GALAXY-API-KEY", apiKey)
+	} else if c.token != "" {
+		req.Header.Set("Authorization", "Bearer "+c.token)
+	}
+}
