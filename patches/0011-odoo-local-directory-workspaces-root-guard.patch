+// TestIsSameOrUnderPath locks the path-boundary semantics used by the
+// workspaces-root containment check: equal-or-nested is true, a sibling that
+// merely shares a string prefix ("/a/b" vs "/a/bad") is not.
+func TestIsSameOrUnderPath(t *testing.T) {
+	cases := []struct {
+		name   string
+		target string
+		base   string
+		want   bool
+	}{
+		{"equal", "/a/b", "/a/b", true},
+		{"nested", "/a/b/c", "/a/b", true},
+		{"prefix collision sibling", "/a/bad", "/a/b", false},
+		{"sibling", "/a/c", "/a/b", false},
+		{"parent of base", "/a", "/a/b", false},
+		{"empty base", "/a/b", "", false},
+	}
+	for _, tc := range cases {
+		t.Run(tc.name, func(t *testing.T) {
+			if got := isSameOrUnderPath(tc.target, tc.base); got != tc.want {
+				t.Errorf("isSameOrUnderPath(%q, %q) = %v, want %v", tc.target, tc.base, got, tc.want)
+			}
+		})
+	}
 }
 
