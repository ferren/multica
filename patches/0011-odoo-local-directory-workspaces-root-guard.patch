+// canonicalWorkspacesRoot returns the symlink-resolved, cleaned form of the
+// daemon's workspaces root, or "" if it is unset or unresolvable. Used by
+// validateLocalPath to compare candidate local_directory paths on equal
+// canonical footing.
+func canonicalWorkspacesRoot(workspacesRoot string) string {
+	wr := strings.TrimSpace(workspacesRoot)
+	if wr == "" {
+		return ""
+	}
+	if r, err := filepath.EvalSymlinks(wr); err == nil {
+		return filepath.Clean(r)
+	}
+	return filepath.Clean(wr)
+}
+
+// isSameOrUnderPath reports whether target is equal to base or nested below
+// it (base is a path-boundary prefix of target). It uses filepath.Rel so the
+// "/a/b" vs "/a/bad" boundary is handled correctly, not by raw string prefix.
+func isSameOrUnderPath(target, base string) bool {
+	if base == "" {
+		return false
+	}
+	if target == base {
+		return true
+	}
+	rel, err := filepath.Rel(base, target)
+	if err != nil {
+		return false
+	}
+	return rel != "." && rel != ".." && !strings.HasPrefix(rel, "../")
+}
