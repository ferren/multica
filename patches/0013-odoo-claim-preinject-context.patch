+// convertRecentCommentsForEnv copies the daemon-side CoalescedCommentData slice
+// (the claim response's `recent_comments`, 方案B / TASK-1-17-1) into the
+// execenv-local RecentCommentForEnv slice the brief renderer consumes. The two
+// types are field-for-field identical by design — a separate execenv type
+// exists only to keep daemon out of execenv's import graph.
+func convertRecentCommentsForEnv(comments []CoalescedCommentData) []execenv.RecentCommentForEnv {
+	if len(comments) == 0 {
+		return nil
+	}
+	result := make([]execenv.RecentCommentForEnv, len(comments))
+	for i, c := range comments {
+		result[i] = execenv.RecentCommentForEnv{
+			ID:         c.ID,
+			ThreadID:   c.ThreadID,
+			AuthorType: c.AuthorType,
+			AuthorName: c.AuthorName,
+			Content:    c.Content,
+			CreatedAt:  c.CreatedAt,
+		}
+	}
+	return result
 }
 
